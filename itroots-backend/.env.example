# Choose one database style:
# 1. Preferred for Coolify/Postgres services:
DB_DIALECT=postgres
DATABASE_URL=postgres://postgres:postgres@postgres:5432/itroots_db

# 2. Or explicit connection fields:
# DB_HOST=postgres
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=itroots_db

PORT=5000
JWT_SECRET=change-this-secret

# Zoom Meeting SDK credentials
ZOOM_MEETING_SDK_KEY=your_zoom_meeting_sdk_key
ZOOM_MEETING_SDK_SECRET=your_zoom_meeting_sdk_secret

# Optional prefix for auto-generated Jitsi room names
JITSI_ROOM_PREFIX=itroots-live
